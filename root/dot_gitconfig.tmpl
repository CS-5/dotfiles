[user]
  name = Carson Seese
  email = {{ .personalEmail }}
{{- if not .isCodespaces }}
  signingkey = key::{{ .gitSigningPubKey }}
{{- end }}

{{ if eq .hostname "CSMBP" -}}
[includeIf "gitdir:~/dev/work/"]
  path = .gitconfig-work
{{- else if .isWorkDc }}
[include]
  path = .gitconfig-work
{{- end }}

[core]
  fsmonitor = true
  excludesfile = {{ joinPath .chezmoi.homeDir ".gitignore-global" | replace "\\" "/" }}
{{- if .isWsl }}
  sshCommand = ssh.exe
{{- else if .isWindows }}
  sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{- end }}

[merge]
  conflictstyle = zdiff3
  ff = false

[rerere]
  enabled = true

{{ if eq .os "windows" -}}
[credential]
  helper = manager
{{- end }}

[credential "https://github.com"]
  helper =
  helper = !gh auth git-credential

[credential "https://gist.github.com"]
  helper =
  helper = !gh auth git-credential

{{ if not .isCodespaces -}}
[commit]
  gpgSign = true

[tag]
  gpgSign = true

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = {{ joinPath .chezmoi.homeDir ".ssh/allowed_signers" | replace "\\" "/" }}
{{- if .isWindows }}
  program = C:/Windows/System32/OpenSSH/ssh-keygen.exe
{{- end }}
{{- end }}

[alias]
  pushfwl = push --force-with-lease

[pull]
  rebase = true